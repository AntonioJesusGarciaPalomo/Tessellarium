# Tessellarium — Environment Configuration
# Copy to .env and fill in your Azure credentials

# Azure Foundry
AZURE_FOUNDRY_ENDPOINT=https://your-project.ai.azure.com
AZURE_FOUNDRY_PROJECT=your-project-name

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-openai.openai.azure.com/
AZURE_OPENAI_API_KEY=your-key
AZURE_OPENAI_API_VERSION=2025-12-01-preview
MODEL_GPT4O=gpt-4o
MODEL_GPT4O_MINI=gpt-4o-mini

# Azure Content Understanding
CONTENT_UNDERSTANDING_ENDPOINT=https://your-cu.cognitiveservices.azure.com/

# Azure AI Search (used by Foundry IQ)
SEARCH_ENDPOINT=https://your-search.search.windows.net
SEARCH_API_KEY=your-key
SEARCH_INDEX_NAME=tessellarium-protocols

# Azure Content Safety
CONTENT_SAFETY_ENDPOINT=https://your-safety.cognitiveservices.azure.com/
CONTENT_SAFETY_API_KEY=your-key

# Azure Cosmos DB
COSMOS_ENDPOINT=https://your-cosmos.documents.azure.com:443/
COSMOS_KEY=your-key
COSMOS_DATABASE=tessellarium
COSMOS_SESSIONS_CONTAINER=sessions
COSMOS_THREADS_CONTAINER=threads

# Azure Blob Storage
STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
STORAGE_UPLOADS_CONTAINER=uploads
STORAGE_PROCESSED_CONTAINER=processed
STORAGE_LITERATURE_CONTAINER=literature

# Lean 4 Verification Service
LEAN_SERVICE_URL=http://ca-tessellarium-lean:8000/mcp
LEAN_MCP_TOKEN=your-lean-mcp-token
LEAN_TIMEOUT_SECONDS=30
